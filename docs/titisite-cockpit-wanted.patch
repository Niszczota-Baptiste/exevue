@@ -16,6 +17,30 @@ import { memberCurrentDone, potentialGains } from './store.js';
 
 const DEADLINE_HORIZON_S = 72 * 3600; // surface a due date within 72 h
 
+// Wanted resources (Minecraft wishlist) not yet gathered, scoped to the
+// workspaces the member belongs to — admins see every workspace, mirroring
+// canAccessWorkspace(). No FK to quests: this is the same PULL feed reused to
+// surface the shopping list next to the quest reminders.
+function wantedFor(member) {
+  const select = `
+    SELECT w.id, w.name, w.quantity, w.priority, w.note,
+           ws.name AS workspace, ws.slug AS workspaceSlug
+    FROM minecraft_wanted w
+    JOIN workspaces ws ON ws.id = w.workspace_id
+  `;
+  if (member.role === 'admin') {
+    return db.prepare(`${select}
+      WHERE w.done = 0
+      ORDER BY w.priority, w.position, w.id
+    `).all();
+  }
+  return db.prepare(`${select}
+    JOIN workspace_members m ON m.workspace_id = w.workspace_id
+    WHERE m.user_id = ? AND w.done = 0
+    ORDER BY w.priority, w.position, w.id
+  `).all(member.id);
+}
